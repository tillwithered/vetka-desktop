{
  "name": "desktop",
  "productName": "Vetka Desktop",
  "version": "1.0.33",
  "description": "Локальная рабочая система Vetka Dolls",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "prepare:chromium": "node scripts/prepare-playwright-chromium.mjs",
    "package": "npm run prepare:chromium && npx --yes --package=node@22 node node_modules/@electron-forge/cli/dist/electron-forge.js package",
    "make": "npm run prepare:chromium && npx --yes --package=node@22 node node_modules/@electron-forge/cli/dist/electron-forge.js make",
    "publish": "electron-forge publish",
    "release:verify-version": "node scripts/verify-release-version.mjs",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "catalog:audit": "vitest run tests/main/catalog-audit.test.ts",
    "catalog:coverage": "vite-node scripts/verify-amazon-catalog-coverage.ts",
    "collectibles:live-check": "vite-node scripts/verify-mattel-creations-live.ts"
  },
  "keywords": [],
  "author": {
    "name": "Codex",
    "email": "codex@local"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "43.1.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "playwright-core": "^1.61.1",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  }
}
